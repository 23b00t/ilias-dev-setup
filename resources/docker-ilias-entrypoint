[cache]
activate_global_cache = 0
global_cache_service_type = 0
"
PHP_INI="
memory_limit = ${ILIAS_MEMORY_LIMIT}
error_reporting = E_ALL & ~E_NOTICE & ~E_WARNING & ~E_STRICT
log_errors = On
max_execution_time = 900
max_input_time = 900
max_input_vars = 10000
upload_max_filesize = ${ILIAS_MAX_UPLOAD_SIZE}
post_max_size = ${ILIAS_MAX_UPLOAD_SIZE}
session.gc_maxlifetime = ${ILIAS_SESSION_LIFETIME}
"
CRON="
*/10 * * * * root su www-data -s /bin/sh -c \"/usr/local/bin/php ${ILIAS_WWW_PATH}/cli/cron.php run-jobs root ${ILIAS_CLIENT_NAME}\" 1>/proc/1/fd/1 2>/proc/1/fd/2
"
INSTALL_JSON="
{
    \"common\" : {
        \"client_id\" : \"${ILIAS_CLIENT_NAME}\"
    },
    \"database\" : {
        \"type\" : \"${ILIAS_DB_TYPE}\",
        \"host\" : \"${ILIAS_DB_HOST}\",
        \"database\" : \"${ILIAS_DB_NAME}\",
        \"user\" : \"${ILIAS_DB_USER}\",
        \"password\" : \"${ILIAS_DB_PASSWORD}\",
        \"path_to_db_dump\" : \"${ILIAS_DB_DUMP}\",
        \"port\" : \"${ILIAS_DB_PORT}\",
        \"create_database\": false
    },
    \"filesystem\" : {
        \"data_dir\" : \"${ILIAS_ILIASDATA_PATH}\"
    },
    \"http\" : {
        \"path\" : \"${ILIAS_HTTP_PATH}\"
    },
    \"systemfolder\" : {
        \"contact\" : {
            \"firstname\" : \"Systemadministrator\",
            \"lastname\" : \"ILIAS\",
            \"email\" : \"noreply@example.com\"
        }
    }
}
"

setup_lucene() {
	LUCENE_LIB_DIR="${ILIAS_WWW_PATH}/components/ILIAS/WebServices/RPC/lib"

	# Wenn die Lib nicht existiert (z.B. andere Branches), einfach überspringen
	if [ ! -d "${LUCENE_LIB_DIR}" ]; then
		echo "Lucene lib directory not found, skipping Lucene setup"
		return 0
	fi

	# /var/iliasdata aus /var/iliasdata/ilias ableiten
	LUCENE_BASE_DIR="$(dirname "${ILIAS_ILIASDATA_PATH}")"
	LUCENE_INDEX_PATH="${LUCENE_BASE_DIR}/default"
	LUCENE_LOG_DIR="${LUCENE_BASE_DIR}/logs"
	LUCENE_M2_DIR="${LUCENE_BASE_DIR}/.m2"

	# Verzeichnisse im Volume anlegen
	mkdir -p "${LUCENE_INDEX_PATH}" "${LUCENE_LOG_DIR}" "${LUCENE_M2_DIR}"
	chown www-data:www-data "${LUCENE_INDEX_PATH}" "${LUCENE_LOG_DIR}" "${LUCENE_M2_DIR}"

	cd "${LUCENE_LIB_DIR}" || exit 1

	echo "Building Lucene ilServer.jar ..."
	su www-data -s /bin/sh -c "mvn -Dmaven.repo.local=${LUCENE_M2_DIR} -Dmaven.compiler.release=11 clean install"
	mv "${LUCENE_LIB_DIR}/target/ilServer.jar" "${LUCENE_LIB_DIR}/ilServer.jar"
	chown www-data:www-data "${LUCENE_LIB_DIR}/ilServer.jar"

	cat >"${LUCENE_LIB_DIR}/ilServer.properties" <<EOF
[Server]
IpAddress = 127.0.0.1
Port = 11111
IndexPath = ${LUCENE_INDEX_PATH}/
LogFile = ${LUCENE_LOG_DIR}/lucene.log
LogLevel = WARN
NumThreads = 4
RamBufferSize = 256
IndexMaxFileSizeMB = 500
maxClauseCount = 10000

[Client1]
ClientId = ${ILIAS_CLIENT_NAME}
NicId = 0
IliasIniPath = ${ILIAS_WWW_PATH}/ilias.ini.php
EOF

	chown www-data:www-data "${LUCENE_LIB_DIR}/ilServer.properties"
}

mkdir -p "${ILIAS_ERRORS_PATH}" "${ILIAS_ILIASDATA_PATH}"

echo "${PHP_INI}" >${PHP_INI_DIR}/conf.d/ilias.ini
echo "${CRON}" >/etc/cron.d/ilias

# Add ini files
dump_ini_files

# Touch ilias log
touch ${ILIAS_ILIASDATA_PATH}/ilias.log
chown www-data:www-data ${ILIAS_ILIASDATA_PATH}/ilias.log

if [ "${ILIAS_AUTO_SETUP}" -eq "1" ]; then
	if [ ! -f "${ILIAS_INSTALL_CONFIG_PATH}" ]; then
		# Dump install config
		echo "${INSTALL_JSON}" >"${ILIAS_INSTALL_CONFIG_PATH}"
	fi

	if [[ "$1" == apache2* ]] || [ "$1" == php-fpm ]; then
		mysql="mysql
            --host=${ILIAS_DB_HOST}
            --port=${ILIAS_DB_PORT}
            --user=${ILIAS_DB_USER}
            --password=${ILIAS_DB_PASSWORD}
            --skip-ssl
            ${ILIAS_DB_NAME}"

		# Wait for database
		tries=0
		maxTries=6
		until ${mysql} -e "SELECT VERSION();" &>/dev/null; do
			tries=$((tries + 1))
			if [ $tries -gt $maxTries ]; then
				# give up
				echo "Could not connect to database, aborting"
				exit 1
			fi
			echo "Cannot connect to database, waiting"
			sleep 10
		done
		echo "Database connection established"

		if ! ${mysql} -e "SELECT COUNT(*) FROM settings" &>/dev/null; then
			# Run setup
			echo "Running setup"
			su www-data -s /bin/sh -c "php cli/setup.php install -y \
                ${ILIAS_INSTALL_ARGUMENTS} ${ILIAS_INSTALL_CONFIG_PATH}"

			# Customize ilias
			echo "Setting root password"
			${mysql} -e "UPDATE usr_data SET
      passwd = MD5('${ILIAS_ROOT_PASSWORD}'),
                    passwd_enc_type = 'md5'
                WHERE usr_id = 6"

			echo "Setting skin/style"
			${mysql} -e "UPDATE usr_pref SET value = '${ILIAS_DEFAULT_SKIN}'
                WHERE keyword = 'skin'"
			${mysql} -e "UPDATE usr_pref SET value = '${ILIAS_DEFAULT_STYLE}'
                WHERE keyword = 'style'"

			# Overwrite generated ini files
			dump_ini_files

			echo "======================================================="
			echo "ILIAS installed successfully!"
			echo "======================================================="
		else
			echo "======================================================="
			echo "ILIAS already installed!"
			echo "Log in using the following credentials:"
			echo
			echo "User:           root"
			echo "Password:       ${ILIAS_ROOT_PASSWORD}"
			echo "======================================================="
		fi
	fi
else
	echo "ILIAS setup skipped"
fi

# Lucene-Setup und Start only in webserver context, not by CLI-Tools like setup or update
if [[ "$1" == apache2* ]] || [ "$1" = "php-fpm" ]; then
	# Setup lucene server if not already set up
	if [ ! -f "${ILIAS_WWW_PATH}/components/ILIAS/WebServices/RPC/lib/ilServer.jar" ]; then
		setup_lucene
		echo "ILIAS_DEV_SETUP_DONE"
	fi

	# start lucene server only after a successful install
	if [ -f "${ILIAS_WWW_PATH}/components/ILIAS/WebServices/RPC/lib/ilServer.jar" ]; then
		su www-data -s /bin/sh -c "java -jar \
			${ILIAS_WWW_PATH}/components/ILIAS/WebServices/RPC/lib/ilServer.jar \
			${ILIAS_WWW_PATH}/components/ILIAS/WebServices/RPC/lib/ilServer.properties start" &
		echo "lucene_started"
	else
		echo "lucene_skipped (ilServer.jar not found)"
	fi
fi

exec "$@"
